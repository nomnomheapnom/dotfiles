{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "~/.config/fastfetch/logo.txt",
        "type": "ascii",
        "padding": {
            "top": 0,
            "left": 2
        }
    },
    "display": {
        "color": {
            "title": "cyan",
            "separator": "white",
            "keys": "yellow",
            "values": "white"
        },
        "separator": "──>",
        "showTitle": false
    },
    "modules": [
        {
            "type": "custom",
            "format": "┌─[{$user}@{$hostname}] - [{$dir}] - [{$line}]",
            "color": "cyan"
        },
        {
            "type": "custom",
            "format": "└─[$] fastfetch",
            "color": "cyan"
        },
        {
            "type": "break"
        },
        {
            "type": "custom",
            "format": "                  -`                     {$user}@{$hostname}",
            "color": "white"
        },
        {
            "type": "custom",
            "format": "                 .o+`                    ------------------",
            "color": "white"
        },
        {
            "type": "os",
            "format": "               `ooo/                    OS: {}"
        },
        {
            "type": "host",
            "format": "              `+oooo:                   Host: {}"
        },
        {
            "type": "kernel",
            "format": "             `+oooooo:                  Kernel: {}"
        },
        {
            "type": "uptime",
            "format": "              -+oooooo+:                 Uptime: {}"
        },
        {
            "type": "packages",
            "format": "            `/:-:++oooo+:                Packages: {} (pacman)"
        },
        {
            "type": "shell",
            "format": "           `/++++/+++++++:               Shell: {}"
        },
        {
            "type": "display",
            "format": "          `/++++++++++++++:              Display: {}",
            "compact": true
        },
        {
            "type": "wm",
            "format": "         `/+++ooooooooooooo/`            WM: {}"
        },
        {
            "type": "cursor",
            "format": "        ./ooosssso++osssssso+`           Cursor: {}"
        },
        {
            "type": "terminal",
            "format": "       .oossssso-````/ossssss+`          Terminal: {}"
        },
        {
            "type": "terminalfont",
            "format": "      -osssssso.      :ssssssso.         Terminal Font: {}"
        },
        {
            "type": "cpu",
            "format": "     :osssssss/        osssso+++.        CPU: {}"
        },
        {
            "type": "gpu",
            "format": "    /ossssssss/        +ssssooo/-        GPU 1: {}"
        },
        {
            "type": "gpu",
            "index": 1,
            "format": "  `/ossssso+/:-        -:/+osssso+-      GPU 2: {}"
        },
        {
            "type": "memory",
            "format": " `+sso+:-`                 `.-/+oso:     Memory: {}"
        },
        {
            "type": "swap",
            "format": "`++:.                           `-/+/    Swap: {}"
        },
        {
            "type": "disk",
            "path": "/",
            "format": ".`                                 `/    Disk (/): {} - btrfs"
        },
        {
            "type": "localip",
            "format": "                                         Local IP: {}"
        },
        {
            "type": "battery",
            "format": "                                         Battery: {}"
        },
        {
            "type": "locale",
            "format": "                                         Locale: {}"
        },
        {
            "type": "break"
        },
        {
            "type": "custom",
            "format": "",
            "color": "reset"
        },
        {
            "type": "custom",
            "format": "┌─[{$user}@{$hostname}] - [~/.config] - [44]",
            "color": "cyan"
        },
        {
            "type": "custom",
            "format": "└─[$]                                                                                [0:06:44]",
            "color": "cyan"
        }
    ]
}